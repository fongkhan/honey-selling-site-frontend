---
import Layout from '../../layouts/Layout.astro';
import { medusa } from '../../lib/medusa';

// 1. Récupération des produits Medusa
const { products } = await medusa.products().catch((err) => {
  console.warn('[Astro Boutique] Erreur fetch Medusa, utilisation du fallback.', err.message);
  return { products: [] };
});

const fallbackProducts = [
  {
    id: "prod_lav",
    handle: "miel-de-lavande",
    title: "Miel de Lavande de Provence",
    subtitle: "Doux, fleuri, notes de vanille",
    description: "Un miel crémeux d'une grande finesse, très aromatique et légèrement fruité. Récolté au cœur des plateaux de lavande.",
    variants: [
      { id: "var_lav_250", title: "Pot de 250g", calculated_price: { calculated_amount: 790, currency_code: "eur" } }
    ]
  },
  {
    id: "prod_cha",
    handle: "miel-de-chataignier",
    title: "Miel de Châtaignier d'Ardèche",
    subtitle: "Robuste, boisé, amertume subtile",
    description: "Miel corsé et boisé, avec une amertume caractéristique et une belle robe ambrée foncée.",
    variants: [
      { id: "var_cha_250", title: "Pot de 250g", calculated_price: { calculated_amount: 820, currency_code: "eur" } }
    ]
  },
  {
    id: "prod_aca",
    handle: "miel-d-acacia",
    title: "Miel d'Acacia du Jura",
    subtitle: "Liquide, très doux, délicat",
    description: "Un miel très clair, liquide et particulièrement doux en bouche. Sa douceur convient à toute la famille.",
    variants: [
      { id: "var_aca_250", title: "Pot de 250g", calculated_price: { calculated_amount: 690, currency_code: "eur" } }
    ]
  },
  {
    id: "prod_sap",
    handle: "miel-de-sapin",
    title: "Miel de Sapin des Vosges",
    subtitle: "Malté, résineux, arômes des bois",
    description: "Miel de miellat rare et prestigieux. Sa robe est très sombre, et ses arômes résineux et maltés sont uniques.",
    variants: [
      { id: "var_sap_250", title: "Pot de 250g", calculated_price: { calculated_amount: 980, currency_code: "eur" } }
    ]
  }
];

const displayProducts = products.length > 0 ? products : fallbackProducts;
---

<Layout title="Boutique de Miels d'Exception — Miellerie Royale">
  
  <section class="relative py-16 px-4 bg-amber-50/20 border-b border-amber-900/5 overflow-hidden">
    <div class="absolute top-0 right-0 w-80 h-80 bg-orange-100/40 rounded-full blur-3xl"></div>
    <div class="max-w-7xl mx-auto text-center relative z-10 space-y-4">
      <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-amber-100/60 rounded-full text-xs font-semibold text-amber-900 border border-amber-200/50">
        🍯 Miels 100% Purs, Naturels & Français
      </div>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-stone-900 leading-tight">
        Notre Cave à Miels
      </h1>
      <p class="text-stone-500 max-w-xl mx-auto font-light leading-relaxed">
        Sélection de crus récoltés par nos apiculteurs partenaires et issus des plus riches terroirs de France.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      
      <!-- PANNEAU FILTRES (STYLISÉ & SIMPLIFIÉ) -->
      <aside class="lg:col-span-1 space-y-6">
        <div class="bg-white p-6 rounded-3xl border border-amber-900/5 shadow-sm space-y-6">
          <div class="flex items-center justify-between pb-4 border-b border-amber-900/5">
            <h3 class="font-display font-semibold text-stone-900 text-lg">Filtres</h3>
            <span class="text-xs text-amber-800 font-medium">Recherche</span>
          </div>

          <!-- Type de Profil -->
          <div class="space-y-3">
            <h4 class="text-xs font-semibold uppercase tracking-wider text-stone-400">Profil Gustatif</h4>
            <div class="space-y-2">
              <label class="flex items-center gap-2.5 text-sm text-stone-600 cursor-pointer hover:text-amber-800 transition-colors">
                <input type="checkbox" class="rounded border-stone-300 text-amber-600 focus:ring-amber-500 filter-checkbox" value="doux" />
                <span>Miels Doux</span>
              </label>
              <label class="flex items-center gap-2.5 text-sm text-stone-600 cursor-pointer hover:text-amber-800 transition-colors">
                <input type="checkbox" class="rounded border-stone-300 text-amber-600 focus:ring-amber-500 filter-checkbox" value="corse" />
                <span>Miels Corsés</span>
              </label>
              <label class="flex items-center gap-2.5 text-sm text-stone-600 cursor-pointer hover:text-amber-800 transition-colors">
                <input type="checkbox" class="rounded border-stone-300 text-amber-600 focus:ring-amber-500 filter-checkbox" value="fruite" />
                <span>Miels Fruités / Floraux</span>
              </label>
            </div>
          </div>

          <!-- Labels et Certifications -->
          <div class="space-y-3 pt-4 border-t border-amber-900/5">
            <h4 class="text-xs font-semibold uppercase tracking-wider text-stone-400">Certifications</h4>
            <label class="flex items-center gap-2.5 text-sm text-stone-600 cursor-pointer hover:text-amber-800 transition-colors">
              <input type="checkbox" class="rounded border-stone-300 text-amber-600 focus:ring-amber-500 filter-checkbox" value="bio" checked />
              <span>Agriculture Biologique (AB)</span>
            </label>
          </div>
        </div>
      </aside>

      <!-- GRILLE PRODUITS DU CATALOGUE -->
      <main class="lg:col-span-3">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="boutique-products-grid">
          {displayProducts.map((p) => {
            const firstVariant = p.variants?.[0];
            const price = (firstVariant?.calculated_price?.calculated_amount ?? 750) / 100;
            const currency = firstVariant?.calculated_price?.currency_code?.toUpperCase() ?? 'EUR';
            const formattedPrice = new Intl.NumberFormat('fr-FR', { style: 'currency', currency: currency }).format(price);

            // Attributs pour filtrage en JS local léger
            const intensity = p.subtitle?.toLowerCase().includes('doux') ? 'doux' : (p.subtitle?.toLowerCase().includes('robuste') || p.subtitle?.toLowerCase().includes('corse') || p.subtitle?.toLowerCase().includes('résineux') ? 'corse' : 'fruite');

            return (
              <div 
                class="bg-white rounded-3xl border border-amber-900/5 p-5 shadow-sm hover:shadow-xl hover:border-amber-500/20 transition-all duration-500 flex flex-col justify-between group product-item"
                data-profile={intensity}
                data-handle={p.handle}
              >
                <div>
                  <div class="flex justify-between items-center mb-4">
                    <span class="px-2.5 py-0.5 bg-emerald-50 text-emerald-850 text-[10px] font-bold rounded-full uppercase tracking-wider">Bio</span>
                    <span class="text-[10px] text-stone-400 font-semibold uppercase tracking-wider">Cave Royale</span>
                  </div>

                  <a href={`/boutique/${p.handle}`} class="block">
                    <div class="h-44 bg-amber-50 rounded-2xl flex items-center justify-center text-5xl group-hover:scale-105 transition-transform duration-500 mb-5 border border-amber-100">
                      🍯
                    </div>
                  </a>

                  <a href={`/boutique/${p.handle}`} class="block group">
                    <h3 class="font-display text-xl font-bold text-stone-900 mb-0.5 group-hover:text-amber-700 transition-colors">
                      {p.title}
                    </h3>
                  </a>
                  <p class="text-xs font-semibold text-amber-800 uppercase tracking-wider mb-2">
                    {p.subtitle ?? 'Miel Pur & Artisanal'}
                  </p>
                  <p class="text-xs text-stone-500 leading-relaxed font-light line-clamp-3 mb-5">
                    {p.description}
                  </p>
                </div>

                <div class="pt-4 border-t border-amber-900/5 flex items-center justify-between mt-auto">
                  <div class="flex flex-col">
                    <span class="text-[10px] text-stone-400 uppercase tracking-widest">Le pot</span>
                    <span class="text-xl font-bold text-amber-950 font-display">{formattedPrice}</span>
                  </div>

                  {firstVariant ? (
                    <button 
                      class="add-to-cart-btn p-3 bg-amber-600 hover:bg-amber-500 text-stone-900 rounded-full transition-all duration-300 hover:scale-110 flex items-center justify-center shadow-sm"
                      data-variant-id={firstVariant.id}
                      aria-label="Ajouter au panier"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                      </svg>
                    </button>
                  ) : (
                    <a 
                      href={`/boutique/${p.handle}`}
                      class="px-4 py-2 bg-amber-50 text-amber-950 rounded-full text-xs font-bold hover:bg-amber-100 transition-colors"
                    >
                      Détails
                    </a>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </main>
    </div>
  </div>

</Layout>

<script>
  // Script client pour filtrage dynamique instantané
  const checkboxes = document.querySelectorAll('.filter-checkbox');
  const items = document.querySelectorAll('.product-item');

  function filterProducts() {
    // Récupérer les profils cochés
    const checkedProfiles: string[] = [];
    checkboxes.forEach((cb: any) => {
      if (cb.checked && cb.value !== 'bio') {
        checkedProfiles.push(cb.value);
      }
    });

    items.forEach((item: any) => {
      const profile = item.dataset.profile;
      
      if (checkedProfiles.length === 0 || checkedProfiles.includes(profile)) {
        item.style.display = 'flex';
      } else {
        item.style.display = 'none';
      }
    });
  }

  checkboxes.forEach((cb: any) => {
    cb.addEventListener('change', filterProducts);
  });

  // Gestion ajout panier AJAX
  document.querySelectorAll('.add-to-cart-btn').forEach((btn: any) => {
    btn.addEventListener('click', (e: Event) => {
      e.preventDefault();
      const variantId = btn.dataset.variantId;
      if (!variantId) return;

      window.dispatchEvent(
        new CustomEvent('add-to-cart', {
          detail: {
            variantId,
            quantity: 1,
          },
        })
      );
    });
  });
</script>
