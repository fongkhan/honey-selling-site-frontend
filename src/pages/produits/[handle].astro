---
import { medusa, type MedusaProduct } from '~/lib/medusa';

export async function getStaticPaths() {
  const { products } = await medusa.products();
  return products.map((product: MedusaProduct) => ({
    params: { handle: product.handle },
    props: { product },
  }));
}

const { product } = Astro.props;
const variant = product.variants[0];
const price = variant?.calculated_price;
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <title>{product.title}</title>
    <meta name="description" content={product.subtitle ?? product.title} />
  </head>
  <body>
    <article>
      <h1>{product.title}</h1>
      {product.thumbnail && <img src={product.thumbnail} alt={product.title} width="480" />}
      {product.description && <p>{product.description}</p>}
      {price && (
        <p>
          <strong>
            {(price.calculated_amount / 100).toLocaleString('fr-FR', {
              style: 'currency',
              currency: price.currency_code.toUpperCase(),
            })}
          </strong>
        </p>
      )}
      <button data-variant-id={variant?.id} data-buy>Ajouter au panier</button>
    </article>

    <script>
      // Hydratation client-side du panier Medusa : à brancher sur /store/carts.
      // Le SSG sert la fiche produit ; seul le panier/checkout est dynamique.
    </script>
  </body>
</html>
