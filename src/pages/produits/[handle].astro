---
import { medusa, type MedusaProduct } from '~/lib/medusa';

export async function getStaticPaths() {
  const { products } = await medusa.products().catch(() => ({ products: [] }));
  
  const fallbackHandles = ['miel-de-lavande', 'miel-de-chataignier', 'miel-d-acacia', 'miel-de-sapin'];
  const finalProducts = products.length > 0 ? products : fallbackHandles.map(handle => ({
    handle,
    title: handle === 'miel-de-lavande' ? "Miel de Lavande de Provence" : 
           handle === 'miel-de-chataignier' ? "Miel de Châtaignier d'Ardèche" :
           handle === 'miel-d-acacia' ? "Miel d'Acacia du Jura" : "Miel de Sapin des Vosges",
    subtitle: handle === 'miel-de-lavande' ? "Doux, fleuri, notes de vanille" : 
              handle === 'miel-de-chataignier' ? "Robuste, boisé, amertume subtile" :
              handle === 'miel-d-acacia' ? "Liquide, très doux, délicat" : "Malté, résineux, arômes des bois",
    description: "Un miel d'exception, brut et sauvage, récolté et conditionné directement sur place par nos apiculteurs.",
    variants: [
      { id: `var_${handle}_250`, title: "Pot de 250g", calculated_price: { calculated_amount: handle === 'miel-de-lavande' ? 7.90 : handle === 'miel-de-chataignier' ? 8.20 : handle === 'miel-d-acacia' ? 6.90 : 9.80, currency_code: "eur" } }
    ]
  }));

  return finalProducts.map((product: any) => ({
    params: { handle: product.handle },
    props: { product },
  }));
}

const { product } = Astro.props;
const displayProduct = product || {
  title: "Miel d'Exception",
  description: "Un miel de qualité supérieure.",
  variants: [{ id: "fallback_var", calculated_price: { calculated_amount: 7.50, currency_code: "eur" } }]
};
const variant = displayProduct.variants?.[0];
const price = variant?.calculated_price;
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <title>{displayProduct.title}</title>
    <meta name="description" content={displayProduct.subtitle ?? displayProduct.title} />

    <!-- JSON-LD Product Schema for SEO -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      "name": displayProduct.title,
      "description": displayProduct.description ?? displayProduct.subtitle,
      "offers": {
        "@type": "Offer",
        "price": variant?.calculated_price?.calculated_amount ?? 7.50,
        "priceCurrency": variant?.calculated_price?.currency_code?.toUpperCase() ?? 'EUR',
        "availability": "https://schema.org/InStock",
        "url": Astro.url.href
      }
    })} />
  </head>
  <body>
    <article>
      <h1>{displayProduct.title}</h1>
      {displayProduct.thumbnail && <img src={displayProduct.thumbnail} alt={displayProduct.title} width="480" />}
      {displayProduct.description && <p>{displayProduct.description}</p>}
      {price && (
        <p>
          <strong>
            {price.calculated_amount.toLocaleString('fr-FR', {
              style: 'currency',
              currency: price.currency_code.toUpperCase(),
            })}
          </strong>
        </p>
      )}
      <button data-variant-id={variant?.id} data-buy>Ajouter au panier</button>
    </article>

    <script>
      // Hydratation client-side du panier Medusa : à brancher sur /store/carts.
      // Le SSG sert la fiche produit ; seul le panier/checkout est dynamique.
    </script>
  </body>
</html>
