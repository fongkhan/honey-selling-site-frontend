---
import Layout from '../layouts/Layout.astro';

const MEDUSA_URL = import.meta.env.MEDUSA_PUBLIC_URL ?? 'http://localhost:9000';
const PUBLISHABLE_KEY = import.meta.env.MEDUSA_PUBLISHABLE_KEY ?? '';
const PUBLIC_STRIPE_KEY = import.meta.env.PUBLIC_STRIPE_KEY ?? '';
---

<Layout title="Finaliser ma commande">
  <!-- Stripe JS SDK Injection (Désactivé car paiement 100% physique) -->
  <!-- <script src="https://js.stripe.com/v3/" is:inline></script> -->
  <div id="stripe-config" data-stripe-key={PUBLIC_STRIPE_KEY} class="hidden"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
    <!-- Fil d'Ariane élégant -->
    <nav class="flex mb-8 text-sm font-medium text-stone-500 gap-2 items-center" aria-label="Breadcrumb">
      <a href="/boutique" class="hover:text-amber-700 transition-colors">Notre Boutique</a>
      <span class="text-stone-300">/</span>
      <span class="text-amber-950 font-semibold">Finaliser la commande</span>
    </nav>

    <!-- Loader de chargement initial -->
    <div id="checkout-initial-loader" class="flex flex-col items-center justify-center py-20 text-center space-y-4">
      <div class="relative h-16 w-16">
        <div class="absolute inset-0 rounded-full border-4 border-amber-100 border-t-amber-600 animate-spin"></div>
        <span class="absolute inset-0 flex items-center justify-center text-xl">🐝</span>
      </div>
      <p class="text-stone-600 font-medium animate-pulse">Chargement de votre panier apicole...</p>
    </div>

    <!-- Message de panier vide (Masqué par défaut) -->
    <div id="checkout-empty-state" class="hidden flex-col items-center justify-center py-20 text-center space-y-6 max-w-md mx-auto bg-white border border-amber-900/5 p-8 rounded-3xl shadow-sm">
      <span class="text-6xl animate-bounce" aria-hidden="true">🐝</span>
      <h2 class="font-display text-2xl font-bold text-amber-950">Votre panier est vide</h2>
      <p class="text-stone-500 text-sm">Vous devez ajouter des miels d'exception dans votre panier avant de pouvoir passer une commande.</p>
      <a href="/boutique" class="inline-block px-8 py-3 bg-amber-600 hover:bg-amber-500 text-stone-900 font-bold rounded-full transition-colors shadow-md hover:shadow-lg focus-visible:ring-2 focus-visible:ring-amber-500 focus:outline-none">
        Retourner à la boutique
      </a>
    </div>

    <!-- Message Hors ligne / Panne Serveur (Masqué par défaut) -->
    <div id="checkout-offline-state" class="hidden flex-col items-center justify-center py-20 text-center space-y-6 max-w-md mx-auto bg-white border border-amber-900/5 p-8 rounded-3xl shadow-sm" role="alert" aria-live="assertive">
      <span class="text-6xl animate-pulse" aria-hidden="true">🐝🔌</span>
      <h2 class="font-display text-2xl font-bold text-amber-950">La ruche est inaccessible</h2>
      <p class="text-stone-500 text-sm">Nous ne parvenons pas à contacter notre miellerie pour charger votre panier. Veuillez vérifier votre connexion internet et réessayer.</p>
      <button 
        id="retry-checkout-btn" 
        type="button" 
        class="px-8 py-3 bg-amber-600 hover:bg-amber-500 text-stone-900 font-bold rounded-full transition-colors shadow-md hover:shadow-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-500 focus-visible:ring-offset-2"
      >
        Réessayer de charger
      </button>
    </div>

    <!-- Conteneur Principal du Checkout (Masqué pendant le chargement) -->
    <div id="checkout-main-container" class="hidden grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <!-- Colonne de gauche : Formulaires de checkout -->
      <div class="lg:col-span-7 space-y-6">
        
        <!-- ÉTAPE 1 : COORDONNÉES DE CONTACT -->
        <div class="bg-white border border-amber-900/5 rounded-3xl p-6 md:p-8 shadow-sm transition-all duration-300 relative overflow-hidden" id="step-1-card" aria-labelledby="step-1-title" role="region">
          <!-- Indicateur d'étape -->
          <div class="absolute top-0 right-0 h-2 w-full bg-amber-100/50" id="step-1-progress-bar"></div>
          
          <div class="flex items-start justify-between mb-6">
            <div class="flex items-center gap-4">
              <span class="h-8 w-8 rounded-full bg-amber-100 text-amber-900 flex items-center justify-center font-bold text-sm" aria-hidden="true">1</span>
              <h3 id="step-1-title" class="font-display text-xl font-bold text-amber-950">Informations de contact</h3>
            </div>
            <button id="edit-step-1-btn" type="button" class="hidden text-xs font-semibold text-amber-700 hover:text-amber-900 underline transition-colors focus-visible:ring-2 focus-visible:ring-amber-500 focus:outline-none" aria-label="Modifier l'adresse email de contact">Modifier</button>
          </div>

          <!-- Formulaire de contact -->
          <div id="step-1-form-container" class="space-y-4">
            <div>
              <label for="contact-email" class="block text-xs font-bold text-amber-950 uppercase tracking-wider mb-2">Adresse Email</label>
              <input 
                type="email" 
                id="contact-email" 
                placeholder="jean.dupont@exemple.com" 
                class="w-full px-4 py-3 bg-stone-50 rounded-xl border border-stone-200 text-stone-950 focus:outline-none focus:border-amber-600 focus:bg-white focus-visible:ring-2 focus-visible:ring-amber-500 transition-all text-sm font-medium"
                required
                autocomplete="email"
                aria-required="true"
                aria-describedby="contact-email-desc"
              />
              <p id="contact-email-desc" class="text-[11px] text-stone-400 mt-1.5">Pour le suivi de votre livraison de miel et l'envoi de votre reçu.</p>
            </div>

            <!-- Panneau d'erreur d'étape 1 (Masqué par défaut) -->
            <div id="step-1-error-panel" class="hidden p-4 bg-red-50 border border-red-200 text-red-800 rounded-2xl text-xs sm:text-sm font-medium flex items-start gap-2.5 mt-2 animate-fade-in" role="alert" aria-live="assertive">
              <span class="text-base" aria-hidden="true">⚠️</span>
              <div class="flex-grow">
                <p id="step-1-error-text">Veuillez entrer une adresse email valide.</p>
              </div>
            </div>

            <button 
              id="submit-step-1-btn"
              type="button"
              class="w-full sm:w-auto px-6 py-2.5 sm:px-8 sm:py-3 bg-amber-600 hover:bg-amber-500 text-stone-900 font-bold rounded-full transition-colors text-sm shadow-sm flex items-center justify-center gap-2 focus-visible:ring-2 focus-visible:ring-amber-500 focus-visible:ring-offset-2 focus:outline-none"
            >
              <span class="whitespace-nowrap">Continuer vers la livraison</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </div>

          <!-- Résumé étape 1 (quand validée) -->
          <div id="step-1-summary" class="hidden text-sm text-stone-600 mt-2 font-medium bg-amber-50/30 p-3.5 rounded-xl border border-amber-500/10">
            <p>Email : <span id="summary-email" class="text-stone-900 font-semibold"></span></p>
          </div>
        </div>

        <!-- ÉTAPE 2 : ADRESSE DE LIVRAISON -->
        <div class="bg-white border border-amber-900/5 rounded-3xl p-6 md:p-8 shadow-sm transition-all duration-300 opacity-50 pointer-events-none relative overflow-hidden" id="step-2-card" aria-labelledby="step-2-title" role="region" aria-disabled="true">
          <div class="absolute top-0 right-0 h-2 w-full bg-stone-100" id="step-2-progress-bar"></div>
          
          <div class="flex items-start justify-between mb-6">
            <div class="flex items-center gap-4">
              <span class="h-8 w-8 rounded-full bg-stone-100 text-stone-500 flex items-center justify-center font-bold text-sm" id="step-2-num" aria-hidden="true">2</span>
              <h3 class="font-display text-xl font-bold text-stone-400 transition-colors" id="step-2-title">Adresse de livraison</h3>
            </div>
            <button id="edit-step-2-btn" type="button" class="hidden text-xs font-semibold text-amber-700 hover:text-amber-900 underline transition-colors focus-visible:ring-2 focus-visible:ring-amber-500 focus:outline-none" aria-label="Modifier l'adresse de livraison">Modifier</button>
          </div>

          <!-- Formulaire d'adresse -->
          <div id="step-2-form-container" class="hidden space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="shipping-first-name" class="block text-xs font-bold text-amber-950 uppercase tracking-wider mb-2">Prénom</label>
                <input 
                  type="text" 
                  id="shipping-first-name" 
                  placeholder="Jean" 
                  class="w-full px-4 py-3 bg-stone-50 rounded-xl border border-stone-200 text-stone-950 focus:outline-none focus:border-amber-600 focus:bg-white focus-visible:ring-2 focus-visible:ring-amber-500 transition-all text-sm font-medium"
                  required
                  autocomplete="given-name"
                  aria-required="true"
                />
              </div>
              <div>
                <label for="shipping-last-name" class="block text-xs font-bold text-amber-950 uppercase tracking-wider mb-2">Nom de famille</label>
                <input 
                  type="text" 
                  id="shipping-last-name" 
                  placeholder="Dupont" 
                  class="w-full px-4 py-3 bg-stone-50 rounded-xl border border-stone-200 text-stone-950 focus:outline-none focus:border-amber-600 focus:bg-white focus-visible:ring-2 focus-visible:ring-amber-500 transition-all text-sm font-medium"
                  required
                  autocomplete="family-name"
                  aria-required="true"
                />
              </div>
            </div>

            <div>
              <label for="shipping-address" class="block text-xs font-bold text-amber-950 uppercase tracking-wider mb-2">Adresse postale</label>
              <input 
                type="text" 
                id="shipping-address" 
                placeholder="12 rue de la Paix" 
                class="w-full px-4 py-3 bg-stone-50 rounded-xl border border-stone-200 text-stone-950 focus:outline-none focus:border-amber-600 focus:bg-white focus-visible:ring-2 focus-visible:ring-amber-500 transition-all text-sm font-medium"
                required
                autocomplete="street-address"
                aria-required="true"
              />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div class="sm:col-span-1">
                <label for="shipping-postal-code" class="block text-xs font-bold text-amber-950 uppercase tracking-wider mb-2">Code Postal</label>
                <input 
                  type="text" 
                  id="shipping-postal-code" 
                  placeholder="75002" 
                  class="w-full px-4 py-3 bg-stone-50 rounded-xl border border-stone-200 text-stone-950 focus:outline-none focus:border-amber-600 focus:bg-white focus-visible:ring-2 focus-visible:ring-amber-500 transition-all text-sm font-medium"
                  required
                  autocomplete="postal-code"
                  aria-required="true"
                />
              </div>
              <div class="sm:col-span-2">
                <label for="shipping-city" class="block text-xs font-bold text-amber-950 uppercase tracking-wider mb-2">Ville</label>
                <input 
                  type="text" 
                  id="shipping-city" 
                  placeholder="Paris" 
                  class="w-full px-4 py-3 bg-stone-50 rounded-xl border border-stone-200 text-stone-950 focus:outline-none focus:border-amber-600 focus:bg-white focus-visible:ring-2 focus-visible:ring-amber-500 transition-all text-sm font-medium"
                  required
                  autocomplete="address-level2"
                  aria-required="true"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="shipping-phone" class="block text-xs font-bold text-amber-950 uppercase tracking-wider mb-2">Téléphone</label>
                <input 
                  type="tel" 
                  id="shipping-phone" 
                  placeholder="06 12 34 56 78" 
                  class="w-full px-4 py-3 bg-stone-50 rounded-xl border border-stone-200 text-stone-950 focus:outline-none focus:border-amber-600 focus:bg-white focus-visible:ring-2 focus-visible:ring-amber-500 transition-all text-sm font-medium"
                  required
                  autocomplete="tel"
                  aria-required="true"
                />
              </div>
              <div>
                <label for="shipping-country" class="block text-xs font-bold text-amber-950 uppercase tracking-wider mb-2">Pays</label>
                <input 
                  type="text" 
                  id="shipping-country" 
                  value="France" 
                  class="w-full px-4 py-3 bg-stone-200 rounded-xl border border-stone-200 text-stone-500 font-semibold text-sm cursor-not-allowed"
                  disabled
                />
              </div>
            </div>

            <!-- Panneau d'erreur d'étape 2 (Masqué par défaut) -->
            <div id="step-2-error-panel" class="hidden p-4 bg-red-50 border border-red-200 text-red-800 rounded-2xl text-xs sm:text-sm font-medium flex items-start gap-2.5 mt-2 animate-fade-in" role="alert" aria-live="assertive">
              <span class="text-base" aria-hidden="true">⚠️</span>
              <div class="flex-grow">
                <p id="step-2-error-text">Une erreur de connexion est survenue. Impossible d'enregistrer votre adresse. Veuillez réessayer.</p>
              </div>
            </div>

            <button 
              id="submit-step-2-btn"
              type="button"
              class="w-full sm:w-auto px-6 py-2.5 sm:px-8 sm:py-3 bg-amber-600 hover:bg-amber-500 text-stone-900 font-bold rounded-full transition-colors text-sm shadow-sm flex items-center justify-center gap-2 mt-2 focus-visible:ring-2 focus-visible:ring-amber-500 focus-visible:ring-offset-2 focus:outline-none"
            >
              <span class="whitespace-nowrap">Continuer vers le mode de livraison</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </div>

          <!-- Résumé étape 2 (quand validée) -->
          <div id="step-2-summary" class="hidden text-sm text-stone-600 mt-2 font-medium bg-amber-50/30 p-3.5 rounded-xl border border-amber-500/10">
            <p id="summary-address-name" class="text-stone-900 font-semibold"></p>
            <p id="summary-address-street"></p>
            <p id="summary-address-city"></p>
            <p id="summary-address-phone"></p>
          </div>
        </div>

        <!-- ÉTAPE 3 : MODE DE LIVRAISON -->
        <div class="bg-white border border-amber-900/5 rounded-3xl p-6 md:p-8 shadow-sm transition-all duration-300 opacity-50 pointer-events-none relative overflow-hidden" id="step-3-card" aria-labelledby="step-3-title" role="region" aria-disabled="true">
          <div class="absolute top-0 right-0 h-2 w-full bg-stone-100" id="step-3-progress-bar"></div>
          
          <div class="flex items-start justify-between mb-6">
            <div class="flex items-center gap-4">
              <span class="h-8 w-8 rounded-full bg-stone-100 text-stone-500 flex items-center justify-center font-bold text-sm" id="step-3-num" aria-hidden="true">3</span>
              <h3 class="font-display text-xl font-bold text-stone-400 transition-colors" id="step-3-title">Mode de livraison</h3>
            </div>
            <button id="edit-step-3-btn" type="button" class="hidden text-xs font-semibold text-amber-700 hover:text-amber-900 underline transition-colors focus-visible:ring-2 focus-visible:ring-amber-500 focus:outline-none" aria-label="Modifier le mode de livraison choisi">Modifier</button>
          </div>

          <!-- Options de livraison dynamiques -->
          <div id="step-3-form-container" class="hidden space-y-4">
            
            <div id="shipping-options-list" class="space-y-3" role="radiogroup" aria-labelledby="step-3-title">
              <!-- Injecté en JS -->
              <div class="animate-pulse space-y-2">
                <div class="h-14 bg-stone-100 rounded-xl" aria-hidden="true"></div>
              </div>
            </div>

            <!-- Panneau d'erreur d'étape 3 (Masqué par défaut) -->
            <div id="step-3-error-panel" class="hidden p-4 bg-red-50 border border-red-200 text-red-800 rounded-2xl text-xs sm:text-sm font-medium flex items-start gap-2.5 mt-2 animate-fade-in" role="alert" aria-live="assertive">
              <span class="text-base" aria-hidden="true">⚠️</span>
              <div class="flex-grow">
                <p id="step-3-error-text">Impossible d'enregistrer le mode de livraison choisi. Veuillez vérifier votre connexion réseau.</p>
              </div>
            </div>

            <button 
              id="submit-step-3-btn"
              type="button"
              class="w-full sm:w-auto px-6 py-2.5 sm:px-8 sm:py-3 bg-amber-600 hover:bg-amber-500 text-stone-900 font-bold rounded-full transition-colors text-sm shadow-sm flex items-center justify-center gap-2 mt-2 focus-visible:ring-2 focus-visible:ring-amber-500 focus-visible:ring-offset-2 focus:outline-none"
            >
              <span class="whitespace-nowrap">Continuer vers le paiement</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </div>

          <!-- Résumé étape 3 (quand validée) -->
          <div id="step-3-summary" class="hidden text-sm text-stone-600 mt-2 font-medium bg-amber-50/30 p-3.5 rounded-xl border border-amber-500/10">
            <p>Mode : <span id="summary-shipping-name" class="text-stone-900 font-semibold"></span> (<span id="summary-shipping-price" class="text-amber-700 font-bold"></span>)</p>
          </div>
        </div>

        <!-- ÉTAPE 4 : PAIEMENT SÉCURISÉ & VALIDATION -->
        <!-- ÉTAPE 4 : RÉSERVATION & VALIDATION DE LA COMMANDE -->
        <div class="bg-white border border-amber-900/5 rounded-3xl p-6 md:p-8 shadow-sm transition-all duration-300 opacity-50 pointer-events-none relative overflow-hidden" id="step-4-card" aria-labelledby="step-4-title" role="region" aria-disabled="true">
          <div class="absolute top-0 right-0 h-2 w-full bg-stone-100" id="step-4-progress-bar"></div>
          
          <div class="flex items-center gap-4 mb-6">
            <span class="h-8 w-8 rounded-full bg-stone-100 text-stone-500 flex items-center justify-center font-bold text-sm" id="step-4-num" aria-hidden="true">4</span>
            <h3 class="font-display text-xl font-bold text-stone-400 transition-colors" id="step-4-title">Réservation de ma commande</h3>
          </div>

          <div id="step-4-form-container" class="hidden space-y-6">
            
            <!-- Conteneur Retrait en main propre -->
            <div id="local-pickup-panel" class="bg-stone-50 border border-stone-200 rounded-2xl p-6 space-y-4 text-sm leading-relaxed text-stone-700 shadow-inner">
              <div class="flex items-center gap-3 border-b border-stone-200 pb-3 text-amber-900">
                <span class="text-2xl" aria-hidden="true">🤝</span>
                <div>
                  <h4 class="font-bold text-amber-950 font-display">Paiement de la main à la main</h4>
                  <p class="text-xs text-amber-800/80">Retrait physique & dépôts-vente</p>
                </div>
              </div>
              <p>
                Puisque vous résidez à <strong>Paris ou Clamart</strong>, vous êtes éligible au retrait en main propre. Aucun paiement en ligne n'est requis aujourd'hui.
              </p>
              <p class="bg-amber-50/50 p-4 rounded-xl border border-amber-500/10 text-amber-950 font-medium">
                💡 <strong>Comment procéder ?</strong>
                <br/>
                1. Cliquez sur le bouton "Réserver et Finaliser" ci-dessous.
                <br/>
                2. Votre commande de miels d'exception est immédiatement enregistrée et réservée dans nos stocks.
                <br/>
                3. Nous vous recontactons sous 24h par téléphone ou email pour convenir d'un rendez-vous pour la remise de vos miels, ou pour passer les récupérer dans l'un de nos dépôts-vente partenaires.
              </p>
              <div class="text-xs text-stone-400">
                Contact direct : <a href="tel:+33600000000" class="text-amber-800 font-bold hover:underline">06 00 00 00 00</a> ou <a href="mailto:contact@lamiellerieroyale.fr" class="text-amber-800 font-bold hover:underline">contact@lamiellerieroyale.fr</a>
              </div>
            </div>

            <!-- Conditions d'utilisation -->
            <p class="text-xs text-stone-550 leading-relaxed" id="step-4-terms-text">
              En cliquant sur le bouton ci-dessous, vous validez votre réservation. Vous vous engagez à régler le montant de votre commande directement lors de la remise en main propre (espèces ou virement instantané).
            </p>

            <!-- Panneau d'erreur d'étape 4 (Masqué par défaut) -->
            <div id="step-4-error-panel" class="hidden p-4 bg-red-50 border border-red-200 text-red-800 rounded-2xl text-xs sm:text-sm font-medium flex items-start gap-2.5 mb-2 animate-fade-in" role="alert" aria-live="assertive">
              <span class="text-base" aria-hidden="true">⚠️</span>
              <div class="flex-grow">
                <p id="step-4-error-text">Une erreur réseau inattendue est survenue lors de la finalisation. Veuillez réessayer.</p>
              </div>
            </div>

            <!-- Bouton de paiement final -->
            <button 
              id="checkout-submit-final-btn"
              type="button"
              class="w-full py-3.5 bg-amber-600 hover:bg-amber-500 text-stone-900 rounded-full font-bold text-center transition-colors shadow-md hover:shadow-lg flex items-center justify-center gap-3 text-base focus-visible:ring-2 focus-visible:ring-amber-500 focus-visible:ring-offset-2 focus:outline-none"
            >
              <span class="whitespace-nowrap">Réserver et Finaliser ma commande</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" class="h-5 w-5 flex-shrink-0 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </button>
          </div>
        </div>
        </div>

      </div>


      <!-- Colonne de droite : Résumé de commande -->
      <div class="lg:col-span-5 lg:sticky lg:top-28">
        <div class="bg-amber-50/20 border border-amber-900/5 rounded-3xl p-6 md:p-8 shadow-sm space-y-6">
          <h3 class="font-display text-xl font-bold text-amber-950 flex items-center gap-2">
            <span>📦</span>
            <span>Votre commande</span>
          </h3>

          <!-- Liste des articles -->
          <div id="checkout-summary-items" class="space-y-4 max-h-[350px] overflow-y-auto pr-1">
            <!-- Injecté dynamiquement en JS -->
          </div>

          <div class="border-t border-amber-900/10 pt-6 space-y-3 text-sm font-medium text-stone-600">
            <div class="flex justify-between">
              <span>Sous-total</span>
              <span id="summary-subtotal" class="text-stone-900">0,00 €</span>
            </div>
            <div class="flex justify-between items-center">
              <span>Frais de livraison</span>
              <span id="summary-shipping" class="text-amber-700 font-semibold">Calculé à l'étape 3</span>
            </div>
            
            <div class="border-t border-amber-900/10 pt-4 flex justify-between items-baseline font-display font-bold text-xl text-amber-950">
              <span>Total Général</span>
              <span id="summary-total" class="text-2xl text-amber-900">0,00 €</span>
            </div>
          </div>

          <!-- Garantie de confiance -->
