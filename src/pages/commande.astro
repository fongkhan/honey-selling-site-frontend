  const summaryAddressName = document.getElementById('summary-address-name');
  const summaryAddressStreet = document.getElementById('summary-address-street');
  const summaryAddressCity = document.getElementById('summary-address-city');
  const summaryAddressPhone = document.getElementById('summary-address-phone');

  // DOM Elements - Étape 3
  const step3Card = document.getElementById('step-3-card');
  const step3FormContainer = document.getElementById('step-3-form-container');
  const step3Summary = document.getElementById('step-3-summary');
  const shippingOptionsList = document.getElementById('shipping-options-list');
  const submitStep3Btn = document.getElementById('submit-step-3-btn');
  const editStep3Btn = document.getElementById('edit-step-3-btn');
  const step3Num = document.getElementById('step-3-num');
  const step3Title = document.getElementById('step-3-title');
  const summaryShippingName = document.getElementById('summary-shipping-name');
  const summaryShippingPrice = document.getElementById('summary-shipping-price');

  // DOM Elements - Étape 4
  const step4Card = document.getElementById('step-4-card');
  const step4FormContainer = document.getElementById('step-4-form-container');
  const step4Num = document.getElementById('step-4-num');
  const step4Title = document.getElementById('step-4-title');
  const submitFinalBtn = document.getElementById('checkout-submit-final-btn');
  const stripeLoading = document.getElementById('stripe-loading');
  const stripePaymentWrapper = document.getElementById('stripe-payment-wrapper');

  // DOM Elements - Summary
  const summaryItems = document.getElementById('checkout-summary-items');
  const summarySubtotal = document.getElementById('summary-subtotal');
  const summaryShipping = document.getElementById('summary-shipping');
  const summaryTotal = document.getElementById('summary-total');

  // DOM Elements - Succès
  const successOrderId = document.getElementById('success-order-id');
  const successOrderTotal = document.getElementById('success-order-total');
  const successShippingName = document.getElementById('success-shipping-name');
  const successShippingStreet = document.getElementById('success-shipping-street');
  const successShippingCity = document.getElementById('success-shipping-city');
  const successShippingEmail = document.getElementById('success-shipping-email');
  const successShippingPhone = document.getElementById('success-shipping-phone');

  // DOM Elements - Éléments de robustesse Réseau & Erreurs
  const checkoutOfflineState = document.getElementById('checkout-offline-state');
  const retryCheckoutBtn = document.getElementById('retry-checkout-btn');
  const networkStatusBanner = document.getElementById('network-status-banner');

  const step1ErrorPanel = document.getElementById('step-1-error-panel');
  const step1ErrorText = document.getElementById('step-1-error-text');
  const step2ErrorPanel = document.getElementById('step-2-error-panel');
  const step2ErrorText = document.getElementById('step-2-error-text');
  const step3ErrorPanel = document.getElementById('step-3-error-panel');
  const step3ErrorText = document.getElementById('step-3-error-text');
  const step4ErrorPanel = document.getElementById('step-4-error-panel');
  const step4ErrorText = document.getElementById('step-4-error-text');

  // Formatage de prix (Medusa v2 utilise directement l'unité principale)
  function formatPrice(amount: number) {
    return new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR' }).format(amount);
  }

  // Vérifier l'éligibilité géographique au retrait en main propre (Paris / Clamart)
  function isLocalDeliveryEligible() {
    if (!currentCart || !currentCart.shipping_address) return false;
    const addr = currentCart.shipping_address;
    const city = (addr.city || '').trim().toLowerCase();
    const postalCode = (addr.postal_code || '').trim().toLowerCase();

    const isParis = postalCode.startsWith('75') || city.includes('paris');
    const isClamart = postalCode.startsWith('92140') || city.includes('clamart');

    return isParis || isClamart;
  }

  // Appels API Medusa Store robuste (avec gestion d'erreur réseau / serveur down)
  async function storeFetch(path: string, options: RequestInit = {}) {
    const url = `${MEDUSA_URL}/store${path}`;
    const headers = {
      'Content-Type': 'application/json',
      'x-publishable-api-key': PUBLISHABLE_KEY,
      ...(options.headers || {}),
    };
    try {
      const res = await fetch(url, { ...options, headers });
      if (!res.ok) {
        const errorText = await res.text();
        console.error(`Medusa API error at ${path}:`, res.status, errorText);
        throw new Error(`API Error: ${res.status}`);
      }
      return await res.json();
    } catch (err) {
      console.error(`Fetch error inside storeFetch for ${path}:`, err);
      throw new Error(`Network Error: ${err.message || 'Serveur indisponible'}`);
    }
  }

  // Vérificateur proactif de connexion internet / serveur Medusa
  async function checkConnectivity(): Promise<boolean> {
    try {
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 3000);
      const res = await fetch(`${MEDUSA_URL}/store/regions`, {
        headers: { 'x-publishable-api-key': PUBLISHABLE_KEY },
        signal: controller.signal
      });
      clearTimeout(timeoutId);
      return res.ok;
    } catch (err) {
      return false;
    }
  }

  // Toast premium pour l'état de la connexion en temps réel
  let toastTimeout: any = null;
  function showNetworkToast(isOnline: boolean) {
    if (!networkStatusBanner) return;
    clearTimeout(toastTimeout);

    if (isOnline) {
      networkStatusBanner.className = "fixed bottom-6 left-6 z-50 transform translate-y-0 opacity-100 transition-all duration-500 max-w-sm rounded-2xl border p-4 shadow-xl flex items-center gap-3 bg-green-50 border-green-200 text-green-800 glass-premium animate-fade-in";
      networkStatusBanner.innerHTML = `
        <span class="text-xl" aria-hidden="true">🟢</span>
        <div>
          <h5 class="text-xs font-bold uppercase tracking-wider text-green-950">Connexion Rétablie</h5>
          <p class="text-[11px] text-green-700 font-medium mt-0.5">Services de la miellerie reconnectés.</p>
        </div>
      `;
      toastTimeout = setTimeout(() => {
        networkStatusBanner.classList.add('opacity-0', 'translate-y-20');
        networkStatusBanner.classList.remove('opacity-100', 'translate-y-0');
      }, 4000);
    } else {
      networkStatusBanner.className = "fixed bottom-6 left-6 z-50 transform translate-y-0 opacity-100 transition-all duration-500 max-w-sm rounded-2xl border p-4 shadow-xl flex items-center gap-3 bg-red-50 border-red-200 text-red-800 glass-premium animate-fade-in";
      networkStatusBanner.innerHTML = `
        <span class="text-xl animate-pulse" aria-hidden="true">🔴</span>
        <div>
          <h5 class="text-xs font-bold uppercase tracking-wider text-red-950">Mode Hors Ligne</h5>
          <p class="text-[11px] text-red-700 font-medium mt-0.5">La connexion avec notre miellerie a été interrompue. Vos actions sont en attente.</p>
        </div>
      `;
    }
  }

  // Initialisation de la page
  async function init() {
    emptyState?.classList.add('hidden');
    checkoutOfflineState?.classList.add('hidden');

    // 1. Gérer le retour d'une redirection de paiement réussie (3D Secure)
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('success') === 'true' && urlParams.get('cart_id')) {
      const redirectCartId = urlParams.get('cart_id');
      loader?.classList.remove('hidden');
      mainContainer?.classList.add('hidden');
      try {
        const completeRes = await storeFetch(`/carts/${redirectCartId}/complete`, {
          method: 'POST'
        });
        if (completeRes.type === 'order' && completeRes.order) {
          localStorage.removeItem('medusa_cart_id');
          cartId = null;
          window.dispatchEvent(new Event('cart-updated'));
          showSuccessState(completeRes.order);
          return;
        }
      } catch (e) {
        console.error('Failed to complete order after redirect:', e);
      }
    }

    if (!cartId) {
      showEmptyState();
      return;
    }

    loader?.classList.remove('hidden');
    mainContainer?.classList.add('hidden');

    // Tester la connectivité Medusa
    const isOnline = await checkConnectivity();
    if (!isOnline) {
      showOfflineState();
      return;
    }

    try {
      const data = await storeFetch(`/carts/${cartId}`);
      currentCart = data.cart;

      if (!currentCart.items || currentCart.items.length === 0) {
        showEmptyState();
        return;
      }

      // Remplir le formulaire avec les valeurs existantes si possibles
      if (currentCart.email) {
        emailInput.value = currentCart.email;
      }
      if (currentCart.shipping_address) {
        const addr = currentCart.shipping_address;
        firstNameInput.value = addr.first_name || '';
        lastNameInput.value = addr.last_name || '';
        addressInput.value = addr.address_1 || '';
        postalCodeInput.value = addr.postal_code || '';
        cityInput.value = addr.city || '';
        phoneInput.value = addr.phone || '';
      }

      updateSummaryUI();
      hideInitialLoader();
      
      // Activer l'étape 1
      goToStep(1);

    } catch (e) {
      console.error('Erreur initialisation checkout', e);
      if (e.message.includes('Network') || e.message.includes('Failed') || e.message.includes('TypeError')) {
        showOfflineState();
      } else {
        showEmptyState();
      }
    }
  }

  function hideInitialLoader() {
    loader?.classList.add('hidden');
    mainContainer?.classList.remove('hidden');
  }

  function showEmptyState() {
    loader?.classList.add('hidden');
    emptyState?.classList.remove('hidden');
    mainContainer?.classList.add('hidden');
  }

  function showOfflineState() {
    loader?.classList.add('hidden');
    emptyState?.classList.add('hidden');
    mainContainer?.classList.add('hidden');
    checkoutOfflineState?.classList.remove('hidden');
  }

  // Câbler le bouton de ré-essai de chargement
  retryCheckoutBtn?.addEventListener('click', () => {
    init();
  });

  // Listeners pour l'état en ligne/hors ligne en temps réel
  window.addEventListener('online', () => {
    showNetworkToast(true);
    if (checkoutOfflineState && !checkoutOfflineState.classList.contains('hidden')) {
      init();
    }
  });

  window.addEventListener('offline', () => {
    showNetworkToast(false);
  });

  // Navigation entre les étapes avec gestion a11y (focus et aria)
  function goToStep(stepNum: number) {
    activeStep = stepNum;

    // Reset des opacités et pointer events
    const steps = [
      { num: 1, card: step1Card, form: step1FormContainer, summary: step1Summary, editBtn: editStep1Btn, circle: null, title: null },
      { num: 2, card: step2Card, form: step2FormContainer, summary: step2Summary, editBtn: editStep2Btn, circle: step2Num, title: step2Title },
      { num: 3, card: step3Card, form: step3FormContainer, summary: step3Summary, editBtn: editStep3Btn, circle: step3Num, title: step3Title },
      { num: 4, card: step4Card, form: step4FormContainer, summary: null, editBtn: null, circle: step4Num, title: step4Title }
    ];

    steps.forEach((s) => {
      if (s.num < stepNum) {
        // Étapes passées (validées)
        s.card?.classList.remove('opacity-50', 'pointer-events-none');
        s.card?.setAttribute('aria-disabled', 'false');
        s.form?.classList.add('hidden');
        s.summary?.classList.remove('hidden');
        s.editBtn?.classList.remove('hidden');
        if (s.circle) {
          s.circle.classList.remove('bg-stone-100', 'text-stone-500');
          s.circle.classList.add('bg-green-100', 'text-green-800');
          s.circle.innerText = '✓';
        }
        if (s.title) {
          s.title.classList.remove('text-stone-400');
          s.title.classList.add('text-amber-950');
        }
      } else if (s.num === stepNum) {
        // Étape active
        s.card?.classList.remove('opacity-50', 'pointer-events-none');
        s.card?.setAttribute('aria-disabled', 'false');
        s.form?.classList.remove('hidden');
        if (s.summary) s.summary.classList.add('hidden');
        s.editBtn?.classList.add('hidden');
        if (s.circle) {
          s.circle.classList.remove('bg-green-100', 'text-green-800', 'bg-stone-100', 'text-stone-500');
          s.circle.classList.add('bg-amber-100', 'text-amber-900');
          s.circle.innerText = s.num.toString();
        }
        if (s.title) {
          s.title.classList.remove('text-stone-400');
          s.title.classList.add('text-amber-950');
        }
      } else {
        // Étapes futures
        s.card?.classList.add('opacity-50', 'pointer-events-none');
        s.card?.setAttribute('aria-disabled', 'true');
        s.form?.classList.add('hidden');
        if (s.summary) s.summary.classList.add('hidden');
        s.editBtn?.classList.add('hidden');
        if (s.circle) {
          s.circle.classList.remove('bg-green-100', 'text-green-800', 'bg-amber-100', 'text-amber-900');
          s.circle.classList.add('bg-stone-100', 'text-stone-500');
          s.circle.innerText = s.num.toString();
        }
        if (s.title) {
          s.title.classList.remove('text-amber-950');
          s.title.classList.add('text-stone-400');
        }
      }
    });

    // Ajustement visuel smooth et focus a11y sur la carte
    const targetCard = [step1Card, step2Card, step3Card, step4Card][stepNum - 1];
    if (targetCard) {
      targetCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
      targetCard.setAttribute('tabindex', '-1');
      setTimeout(() => {
        targetCard.focus();
      }, 300);
    }

    // Initialisation du paiement Stripe à l'étape 4
    if (stepNum === 4) {
      initStripePayment();
    }
  }

  // Initialisation de la session de paiement avec provider manuel
  async function initStripePayment() {
    if (!step4ErrorPanel || !step4ErrorText) return;
    
    // Reset visual states
    step4ErrorPanel.classList.add('hidden');

    try {
      // Créer la Collection de Paiement (indispensable pour Medusa v2)
      const collectionRes = await storeFetch('/payment-collections', {
        method: 'POST',
        body: JSON.stringify({ cart_id: cartId })
      });
      const paymentCollectionId = collectionRes.payment_collection.id;

      // Initialiser la session de paiement avec le provider manuel par défaut 'pp_system_default'
      await storeFetch(`/payment-collections/${paymentCollectionId}/payment-sessions`, {
        method: 'POST',
        body: JSON.stringify({ provider_id: 'pp_system_default' })
      });

    } catch (err: any) {
      console.error('Erreur initialisation session de paiement', err);
      if (step4ErrorPanel && step4ErrorText) {
        if (err.message.includes('Network') || err.message.includes('connexion')) {
          step4ErrorText.innerText = 'Une erreur de connexion est survenue. Impossible d\'initialiser votre commande. Veuillez vérifier votre réseau et réessayer.';
        } else {
          step4ErrorText.innerText = `Erreur : ${err.message || 'Impossible d\'enregistrer votre réservation. Veuillez contacter le support.'}`;
        }
        step4ErrorPanel.classList.remove('hidden');
        step4ErrorPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    }
  }

  // Événements d'édition manuelle des étapes validées
  editStep1Btn?.addEventListener('click', () => goToStep(1));
  editStep2Btn?.addEventListener('click', () => goToStep(2));
  editStep3Btn?.addEventListener('click', () => goToStep(3));

  // ÉTAPE 1 : Validation des coordonnées
  submitStep1Btn?.addEventListener('click', () => {
    // Réinitialiser les erreurs
    step1ErrorPanel?.classList.add('hidden');

    const email = emailInput.value.trim();
    if (!email || !emailInput.checkValidity()) {
      if (step1ErrorPanel && step1ErrorText) {
        step1ErrorText.innerText = 'Veuillez entrer une adresse email de contact valide.';
        step1ErrorPanel.classList.remove('hidden');
        step1ErrorPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      return;
    }
    
    // Mettre à jour l'affichage
    if (summaryEmail) summaryEmail.innerText = email;
    goToStep(2);
  });

  // ÉTAPE 2 : Validation de l'adresse de livraison et envoi à Medusa
  submitStep2Btn?.addEventListener('click', async () => {
    // Réinitialiser les erreurs
    step2ErrorPanel?.classList.add('hidden');

    const firstName = firstNameInput.value.trim();
    const lastName = lastNameInput.value.trim();
    const address = addressInput.value.trim();
    const postalCode = postalCodeInput.value.trim();
    const city = cityInput.value.trim();
    const phone = phoneInput.value.trim();

    if (!firstName || !lastName || !address || !postalCode || !city || !phone) {
      if (step2ErrorPanel && step2ErrorText) {
        step2ErrorText.innerText = 'Veuillez remplir tous les champs de l\'adresse de livraison.';
        step2ErrorPanel.classList.remove('hidden');
        step2ErrorPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      return;
    }

    // Validation géographique stricte (Paris 75xxx ou Clamart 92140 uniquement)
    const isParis = postalCode.startsWith('75') || city.toLowerCase().includes('paris');
    const isClamart = postalCode.startsWith('92140') || city.toLowerCase().includes('clamart');

    if (!isParis && !isClamart) {
      if (step2ErrorPanel && step2ErrorText) {
        step2ErrorText.innerHTML = `
          <div class="space-y-2 text-left">
            <p class="font-bold text-red-950 flex items-center gap-1.5 text-sm">
              <span>📍</span> Zone de livraison non éligible
            </p>
            <p class="text-xs text-red-800 leading-relaxed">
              Nous vendons notre miel d'exception <strong>exclusivement en direct et en physique (main propre ou dépôts-vente partenaires)</strong> à proximité de chez nous afin de privilégier un circuit ultra-court.
            </p>
            <p class="text-xs text-red-800 font-semibold">
              Pour commander, votre adresse de livraison doit être située à Paris (75xxx) ou Clamart (92140).
            </p>
          </div>
        `;
        step2ErrorPanel.classList.remove('hidden');
        step2ErrorPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      return;
    }

    // Afficher un loader temporaire sur le bouton
    const origBtnText = submitStep2Btn.innerHTML;
    submitStep2Btn.innerHTML = `<span>Mise à jour en cours...</span><div class="h-4 w-4 border-2 border-stone-900 border-t-transparent animate-spin rounded-full"></div>`;
    submitStep2Btn.setAttribute('disabled', 'true');

    try {
      // 1. Envoyer l'adresse et l'email au panier Medusa
      const body = {
        email: emailInput.value.trim(),
        shipping_address: {
          first_name: firstName,
          last_name: lastName,
          address_1: address,
          postal_code: postalCode,
          city: city,
          country_code: 'fr',
          phone: phone
        }
      };

      const data = await storeFetch(`/carts/${cartId}`, {
        method: 'POST',
        body: JSON.stringify(body)
      });
      currentCart = data.cart;

      // 2. Mettre à jour l'affichage de résumé de livraison
      if (summaryAddressName) summaryAddressName.innerText = `${firstName} ${lastName}`;
      if (summaryAddressStreet) summaryAddressStreet.innerText = address;
      if (summaryAddressCity) summaryAddressCity.innerText = `${postalCode} ${city}`;
      if (summaryAddressPhone) summaryAddressPhone.innerText = `Téléphone : ${phone}`;

      // 3. Charger les options de livraison pour l'étape 3
      await fetchShippingOptions();

      // Mettre à jour les totaux du résumé
      updateSummaryUI();

      // Passer à l'étape 3
      goToStep(3);

    } catch (err) {
      console.error(err);
      if (step2ErrorPanel && step2ErrorText) {
        if (err.message.includes('Network')) {
          step2ErrorText.innerText = 'Une erreur de connexion est survenue. Impossible d\'enregistrer votre adresse. Veuillez vérifier votre réseau et réessayer.';
        } else {
          step2ErrorText.innerText = 'Erreur lors de la mise à jour de l\'adresse de livraison. Veuillez réessayer.';
        }
        step2ErrorPanel.classList.remove('hidden');
        step2ErrorPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    } finally {
      submitStep2Btn.innerHTML = origBtnText;
      submitStep2Btn.removeAttribute('disabled');
    }
  });

  // Charger les options de livraison depuis Medusa
  async function fetchShippingOptions() {
    if (!shippingOptionsList) return;
    
    // Spinner
    shippingOptionsList.innerHTML = `
      <div class="flex items-center gap-3 p-4 bg-stone-50 border border-stone-200 rounded-2xl">
        <div class="h-5 w-5 border-2 border-amber-600 border-t-transparent animate-spin rounded-full"></div>
        <p class="text-xs text-stone-500 font-medium">Recherche des meilleurs modes de retrait...</p>
      </div>
    `;

    try {
      const data = await storeFetch(`/shipping-options?cart_id=${cartId}`);
      availableStandardOptions = data.shipping_options || [];

      if (availableStandardOptions.length === 0) {
        shippingOptionsList.innerHTML = `
          <div class="p-4 bg-red-50 border border-red-100 rounded-2xl text-xs text-red-700">
            Aucun mode de livraison n'est configuré dans le système pour cette adresse. Veuillez modifier vos coordonnées.
          </div>
        `;
        submitStep3Btn?.setAttribute('disabled', 'true');
        return;
      }

      // Proposer EXCLUSIVEMENT le Retrait en main propre (avec Paris et Clamart)
      const localOptionHtml = `
        <label class="flex items-start gap-4 bg-white hover:bg-amber-50/10 p-5 rounded-2xl border border-amber-500 bg-amber-50/20 hover:border-amber-500/50 transition-all duration-300 cursor-pointer shadow-sm relative shipping-option-label animate-fade-in" data-id="so_local_pickup">
          <input 
            type="radio" 
            name="shipping_option" 
            value="so_local_pickup" 
            class="mt-1 accent-amber-600 shipping-option-radio"
            checked
            data-name="Retrait en main propre (Paris & Clamart)"
            data-amount="0"
          />
          <div class="flex-grow min-w-0 -mt-0.5">
            <div class="flex items-center justify-between gap-2">
              <h4 class="text-sm font-bold text-amber-950 flex items-center gap-1.5">
                <span>🤝</span>
                <span>Retrait en main propre & Dépôt-vente</span>
              </h4>
              <span class="text-sm font-extrabold text-amber-900">Offert</span>
            </div>
            <p class="text-xs text-amber-800 mt-1">Réservé aux alentours de Paris et Clamart. Remise physique contre paiement en espèces ou virement.</p>
          </div>
        </label>
      `;

      shippingOptionsList.innerHTML = localOptionHtml;

      // Câbler le changement de sélection pour effet visuel de bordure
      const radios = document.querySelectorAll('.shipping-option-radio');
      radios.forEach((r: any) => {
        r.addEventListener('change', () => {
          document.querySelectorAll('.shipping-option-label').forEach((lbl: any) => {
            lbl.classList.remove('border-amber-500', 'bg-amber-50/20');
            lbl.classList.add('border-stone-200');
          });
          const label = r.closest('.shipping-option-label');
          label?.classList.remove('border-stone-200');
          label?.classList.add('border-amber-500', 'bg-amber-50/20');
        });
      });

      submitStep3Btn?.removeAttribute('disabled');

    } catch (e) {
      console.error(e);
      shippingOptionsList.innerHTML = `
        <div class="p-4 bg-red-50 border border-red-100 rounded-2xl text-xs text-red-750">
          Une erreur est survenue lors de la récupération des options de livraison. Veuillez vérifier votre connexion.
        </div>
      `;
      submitStep3Btn?.setAttribute('disabled', 'true');
    }
  }
  // ÉTAPE 3 : Validation de la livraison
  submitStep3Btn?.addEventListener('click', async () => {
    // Réinitialiser les erreurs
    step3ErrorPanel?.classList.add('hidden');

    const selectedRadio = document.querySelector('input[name="shipping_option"]:checked') as HTMLInputElement;
    if (!selectedRadio) {
      if (step3ErrorPanel && step3ErrorText) {
        step3ErrorText.innerText = 'Veuillez sélectionner un mode de livraison.';
        step3ErrorPanel.classList.remove('hidden');
        step3ErrorPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      return;
    }

    const optionId = selectedRadio.value;
    const isLocal = optionId === 'so_local_pickup';
    isLocalPickupSelected = isLocal;

    const name = isLocal ? 'Retrait en main propre & Dépôt-vente' : (selectedRadio.dataset.name || 'Livraison');
    const amount = isLocal ? 0 : parseInt(selectedRadio.dataset.amount || '0');

    // Loader
    const origBtnText = submitStep3Btn.innerHTML;
    submitStep3Btn.innerHTML = `<span>Application du mode...</span><div class="h-4 w-4 border-2 border-stone-900 border-t-transparent animate-spin rounded-full"></div>`;
    submitStep3Btn.setAttribute('disabled', 'true');

    try {
      let optionIdToApply = optionId;
      if (isLocal) {
        if (availableStandardOptions.length === 0) {
          throw new Error("Aucune option de livraison standard disponible pour valider le panier Medusa.");
        }
        optionIdToApply = availableStandardOptions[0].id;
      }

      // Assigner la livraison sur Medusa
      const data = await storeFetch(`/carts/${cartId}/shipping-methods`, {
        method: 'POST',
        body: JSON.stringify({ option_id: optionIdToApply })
      });
      currentCart = data.cart;

      // Résumé de la livraison
      if (summaryShippingName) summaryShippingName.innerText = name;
      if (summaryShippingPrice) summaryShippingPrice.innerText = isLocal || amount === 0 ? 'Offert' : formatPrice(amount);

      // Mettre à jour l'affichage des totaux
      updateSummaryUI();

      // Aller à l'étape 4
      goToStep(4);

    } catch (e) {
      console.error(e);
      if (step3ErrorPanel && step3ErrorText) {
        if (e.message.includes('Network')) {
          step3ErrorText.innerText = 'Une erreur de connexion est survenue. Impossible d\'enregistrer le mode de livraison. Veuillez vérifier votre connexion.';
        } else {
          step3ErrorText.innerText = 'Erreur lors de la configuration de l\'expédition. Veuillez réessayer.';
        }
        step3ErrorPanel.classList.remove('hidden');
        step3ErrorPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    } finally {
      submitStep3Btn.innerHTML = origBtnText;
      submitStep3Btn.removeAttribute('disabled');
    }
  });

  // ÉTAPE 4 : Validation finale (Réservation physique)
  submitFinalBtn?.addEventListener('click', async () => {
    // Réinitialiser les erreurs
    step4ErrorPanel?.classList.add('hidden');

    // Loader sur le bouton final
    submitFinalBtn.setAttribute('disabled', 'true');
    submitFinalBtn.innerHTML = `
      <span>Réservation de votre commande...</span>
      <div class="h-5 w-5 border-2 border-stone-900 border-t-transparent animate-spin rounded-full"></div>
    `;

    try {
      // Mode Retrait physique : finalisation directe du panier Medusa v2
      const completeRes = await storeFetch(`/carts/${cartId}/complete`, {
        method: 'POST'
      });

      if (completeRes.type === 'order' && completeRes.order) {
        const order = completeRes.order;
        
        // Nettoyer localement le panier
        localStorage.removeItem('medusa_cart_id');
        cartId = null;

        // Déclencher un événement global pour mettre à jour les compteurs du panier
        window.dispatchEvent(new Event('cart-updated'));

        // Afficher l'écran de succès premium
        showSuccessState(order);

      } else {
        throw new Error('La finalisation du panier n\'a pas retourné de commande dans Medusa.');
      }

    } catch (err: any) {
      console.error('Finalisation du checkout échouée', err);
      if (step4ErrorPanel && step4ErrorText) {
        if (err.message.includes('Network') || err.message.includes('réseau')) {
          step4ErrorText.innerText = 'Une erreur réseau est survenue lors de la validation. Veuillez vérifier votre connexion et cliquer de nouveau pour réessayer.';
        } else {
          step4ErrorText.innerText = err.message || 'Une erreur inattendue est survenue lors de la validation de votre réservation. Veuillez réessayer.';
        }
        step4ErrorPanel.classList.remove('hidden');
        step4ErrorPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      submitFinalBtn.removeAttribute('disabled');
      submitFinalBtn.innerHTML = `
        <span>Réserver et Finaliser ma commande</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" class="h-5 w-5 flex-shrink-0 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      `;
    }
  });

  // Affichage du panneau de succès
  function showSuccessState(order: any) {
    mainContainer?.classList.add('hidden');
    successContainer?.classList.remove('hidden');

    if (successOrderId) successOrderId.innerText = order.id;
    if (successOrderTotal) {
      successOrderTotal.innerText = isLocalPickupSelected ? formatPrice(currentCart?.subtotal || order.total) : formatPrice(order.total);
    }

    const addr = order.shipping_address;
    if (successShippingName) successShippingName.innerText = `${addr.first_name} ${addr.last_name}`;
    if (successShippingStreet) successShippingStreet.innerText = addr.address_1;
    if (successShippingCity) successShippingCity.innerText = `${addr.postal_code} ${addr.city}`;
    
    if (successShippingEmail) successShippingEmail.innerText = order.email;
    if (successShippingPhone) successShippingPhone.innerText = addr.phone || '';

    // Ajuster l'affichage des informations de suivi/retrait
    const successPickupInfo = document.getElementById('success-pickup-info');
    const successDeliveryTrackingInfo = document.getElementById('success-delivery-tracking-info');
    
    if (isLocalPickupSelected) {
      successPickupInfo?.classList.remove('hidden');
      successDeliveryTrackingInfo?.classList.add('hidden');
    } else {
      successPickupInfo?.classList.add('hidden');
      successDeliveryTrackingInfo?.classList.remove('hidden');
    }

    // Scroll au sommet
    window.scrollTo({ top: 0, behavior: 'smooth' });
    
    // Focus sur le titre de succès pour accessibilité
    const successTitle = successContainer?.querySelector('h2');
    if (successTitle) {
      successTitle.setAttribute('tabindex', '-1');
      successTitle.focus();
    }
  }

  // Mettre à jour l'UI du résumé de commande de droite
  function updateSummaryUI() {
    if (!currentCart || !summaryItems) return;

    // Rendu des articles
    summaryItems.innerHTML = currentCart.items.map((item: any) => `
      <div class="flex items-center gap-3 bg-white p-3.5 rounded-2xl border border-amber-900/5 hover:border-amber-500/10 transition-all duration-300 shadow-sm">
        <div class="h-12 w-12 bg-amber-50/50 rounded-lg flex items-center justify-center font-display text-lg border border-amber-100">
          🍯
        </div>
        <div class="flex-grow min-w-0 text-xs">
          <h4 class="font-display font-semibold text-stone-900 truncate">${item.title}</h4>
          <p class="text-stone-400 mt-0.5">Format: ${item.variant_title || (item.variant ? item.variant.title : '')}</p>
          <div class="flex items-center justify-between mt-1">
            <span class="text-stone-500 font-medium">${item.quantity} x ${formatPrice(item.unit_price)}</span>
            <span class="font-bold text-amber-950 text-sm">${formatPrice(item.unit_price * item.quantity)}</span>
          </div>
        </div>
      </div>
    `).join('');

    // Rendu des totaux
    if (summarySubtotal) summarySubtotal.innerText = formatPrice(currentCart.subtotal);
    
    if (summaryShipping) {
      if (isLocalPickupSelected) {
        summaryShipping.innerText = "Offert";
        summaryShipping.className = "text-amber-700 font-semibold";
      } else if (currentCart.shipping_methods && currentCart.shipping_methods.length > 0) {
        const cost = currentCart.shipping_methods[0].amount;
        summaryShipping.innerText = cost === 0 ? 'Offert' : formatPrice(cost);
        summaryShipping.className = "text-amber-700 font-semibold";
      } else {
        summaryShipping.innerText = "Calculé à l'étape 3";
        summaryShipping.className = "text-stone-400 italic font-normal";
      }
    }

    if (summaryTotal) {
      summaryTotal.innerText = isLocalPickupSelected ? formatPrice(currentCart.subtotal) : formatPrice(currentCart.total);
    }
  }

  // Lancement
  init();
</script>


<style>
  /* Animations fines pour le checkout */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in {
    animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
