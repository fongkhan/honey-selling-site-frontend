---
import '../styles/global.css';
import CartDrawer from '../components/CartDrawer.astro';
import { payload } from '../lib/payload';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = "Miel artisanal d'exception récolté de manière écoresponsable, direct producteur.", 
  image = "/images/honey-social.jpg" 
} = Astro.props;

// Récupération des paramètres globaux et des pages depuis Payload CMS
const [settings, pagesRes] = await Promise.all([
  payload.settings().catch((err) => {
    console.warn('[Astro Layout] Erreur fetch settings, utilisation des valeurs par défaut.', err.message);
    return { siteName: "La Miellerie Royale", slogan: "Artisans Apiculteurs", favicon: null };
  }),
  payload.pages().catch((err) => {
    console.warn('[Astro Layout] Erreur fetch pages pour la navbar, utilisation du fallback vide.', err.message);
    return { docs: [] };
  })
]);

const siteName = settings?.siteName || "La Miellerie Royale";
const siteSlogan = settings?.slogan || "Artisans Apiculteurs";

// Filtrer et trier les pages dynamiques à afficher dans la barre de navigation
const dynamicNavPages = (pagesRes?.docs || []).length > 0
  ? (pagesRes?.docs || [])
      .filter(p => p.showInNavbar && p.slug !== 'home' && p.slug !== 'boutique')
      .sort((a, b) => (a.navbarOrder ?? 0) - (b.navbarOrder ?? 0))
  : [
      { slug: 'histoire', title: 'Notre Histoire' }
    ];

const PAYLOAD_URL = import.meta.env.PAYLOAD_PUBLIC_URL ?? 'http://localhost:3000';
let faviconUrl = "/favicon.svg";
if (settings?.favicon && typeof settings.favicon === 'object' && settings.favicon.url) {
  faviconUrl = settings.favicon.url.startsWith('http') 
    ? settings.favicon.url 
    : `${PAYLOAD_URL.replace(/\/$/, '')}${settings.favicon.url}`;
}
---

<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href={faviconUrl} />
    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#fdfbf7] text-[#1c1917] flex flex-col min-h-screen">
    
    <!-- Barre de Navigation Glassmorphic -->
    <header class="sticky top-0 z-40 w-full transition-all duration-300 glass-premium border-b border-amber-500/10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-20">
          <!-- Logo & Nom de marque -->
          <a href="/" class="flex items-center gap-2.5 group">
            <span class="text-3xl filter drop-shadow-md group-hover:scale-110 transition-transform duration-300">🐝</span>
            <div class="flex flex-col">
              <span class="font-display font-semibold text-xl tracking-tight text-amber-900 group-hover:text-amber-700 transition-colors duration-300">{siteName}</span>
              <span class="text-[10px] tracking-[0.2em] uppercase text-amber-700/80 font-medium -mt-0.5">{siteSlogan}</span>
            </div>
          </a>

          <!-- Menu de navigation -->
          <nav class="hidden md:flex items-center gap-8 font-medium text-amber-950/80">
            <a href="/boutique" class="hover:text-amber-600 transition-colors duration-200 relative py-1 after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-amber-500 after:transition-all hover:after:w-full">Notre Boutique</a>
            <a href="/recettes-bienfaits" class="hover:text-amber-600 transition-colors duration-200 relative py-1 after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-amber-500 after:transition-all hover:after:w-full">Blog & Vertus</a>
            {dynamicNavPages.map((page) => (
              <a href={`/${page.slug}`} class="hover:text-amber-600 transition-colors duration-200 relative py-1 after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-amber-500 after:transition-all hover:after:w-full">{page.title}</a>
            ))}
          </nav>

          <!-- Bouton Panier et Actions -->
          <div class="flex items-center gap-4">
            <button 
              id="open-cart-btn" 
              class="relative p-3 bg-amber-50 hover:bg-amber-100/80 text-amber-900 rounded-full transition-all duration-300 hover:scale-105 border border-amber-200/50 flex items-center justify-center"
              aria-label="Ouvrir le panier"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
              </svg>
              <span 
                id="cart-badge" 
                class="absolute -top-1 -right-1 h-5 min-w-[20px] px-1 bg-amber-600 text-white text-[10px] font-bold rounded-full flex items-center justify-center scale-0 transition-transform duration-300 border border-white"
              >
                0
              </span>
            </button>
          </div>
        </div>
      </div>
    </header>

    <!-- Contenu Principal -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Panier Latéral -->
    <CartDrawer />

    <!-- Pied de Page (Footer) -->
    <footer class="bg-stone-900 text-stone-300 border-t border-amber-950/20 pt-16 pb-8 mt-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
          <div class="flex flex-col gap-4">
            <div class="flex items-center gap-2">
              <span class="text-3xl">🐝</span>
              <span class="font-display font-semibold text-xl tracking-tight text-white">{siteName}</span>
            </div>
            <p class="text-sm text-stone-400">
              Producteurs passionnés de miel biologique d'exception. Engagés dans la protection de la biodiversité et de nos chères abeilles.
            </p>
          </div>
          
          <div>
            <h3 class="font-display text-white text-lg font-medium mb-6">Découvrir</h3>
            <ul class="space-y-3.5 text-sm">
              <li><a href="/boutique" class="hover:text-amber-400 transition-colors">Notre Boutique</a></li>
              <li><a href="/recettes-bienfaits" class="hover:text-amber-400 transition-colors">Recettes & Astuces</a></li>
              <li><a href="/histoire" class="hover:text-amber-400 transition-colors">La Miellerie & Engagements</a></li>
            </ul>
          </div>
          
          <div>
            <h3 class="font-display text-white text-lg font-medium mb-6">Qualité</h3>
            <ul class="space-y-3.5 text-sm text-stone-400">
              <li class="flex items-center gap-2">🌱 Certifié Biologique</li>
              <li class="flex items-center gap-2">🇫🇷 Origine 100% France</li>
              <li class="flex items-center gap-2">🍯 Non chauffé & non filtré</li>
            </ul>
          </div>
          
          <div>
            <h3 class="font-display text-white text-lg font-medium mb-6">Contact & Newsletter</h3>
            <p class="text-sm text-stone-400 mb-4">Inscrivez-vous pour recevoir des nouvelles de la ruche.</p>
            <div class="flex gap-2">
              <input type="email" placeholder="Votre email" class="w-full px-4 py-2.5 bg-stone-850 rounded-lg text-sm border border-stone-700 text-white focus:outline-none focus:border-amber-500" />
              <button class="px-4 py-2.5 bg-amber-600 hover:bg-amber-500 text-stone-900 rounded-lg font-semibold text-sm transition-colors">Rejoindre</button>
            </div>
          </div>
        </div>
        
        <div class="border-t border-stone-800 pt-8 flex flex-col sm:flex-row items-center justify-between text-xs text-stone-500 gap-4">
          <p>© {new Date().getFullYear()} {siteName}. Conçu avec passion.</p>
          <div class="flex gap-6">
            <a href="#" class="hover:text-stone-400 transition-colors">Mentions Légales</a>
            <a href="#" class="hover:text-stone-400 transition-colors">CGV</a>
            <a href="#" class="hover:text-stone-400 transition-colors">Confidentialité</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
