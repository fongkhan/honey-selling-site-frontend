# Site
PUBLIC_SITE_URL=https://www.example.com

# Payload CMS (content)
PAYLOAD_PUBLIC_URL=https://cms.example.com

# Medusa (commerce)
MEDUSA_PUBLIC_URL=https://shop.example.com
MEDUSA_PUBLISHABLE_KEY=pk_change_me

# Shared webhook secret — must match the value set in
# cms/.env (Payload) and commerce/.env (Medusa).
BUILD_WEBHOOK_SECRET=change-me-to-a-long-random-string
